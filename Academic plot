# Galleries – human-readable keys → matplotlib codes

# ─────────────────────────────────────────────────────────────────────────────

MARKER_GALLERY: dict[str, str] = {
# key              mpl code   shape
“circle”       : “o”,     # ●
“square”       : “s”,     # ■
“triangle_up”  : “^”,     # ▲
“triangle_dn”  : “v”,     # ▼
“triangle_left”: “<”,     # ◀
“triangle_right”: “>”,    # ▶
“diamond”      : “D”,     # ◆
“thin_diamond” : “d”,     # ◇  (narrower)
“pentagon”     : “p”,     # ⬠
“hexagon1”     : “h”,     # ⬡  (flat top)
“hexagon2”     : “H”,     # ⬡  (pointy top)
“star”         : “*”,     # ★
“plus”         : “+”,     # +
“cross”        : “x”,     # ×
“point”        : “.”,     # •  (tiny dot)
“pixel”        : “,”,     # ·  (1 px, invisible at normal DPI)
“none”         : “None”,  #    (no marker – line only)
}

LINE_GALLERY: dict[str, str] = {
# key            mpl code
“solid”        : “-”,
“dashed”       : “–”,
“dash_dot”     : “-.”,
“dotted”       : “:”,
“none”         : “None”,   # scatter / markers only
}

