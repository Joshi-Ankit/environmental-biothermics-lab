@dataclass
class Series:
“”“One plotted data series (primary or secondary Y axis).

```
Attributes
----------
col : str
    Excel column letter (``"A"``…``"ZZ"``) **or** exact header name.
label : str
    Legend text for this series.
marker : str
    Key from MARKER_GALLERY or raw mpl marker code (``"o"``, ``"s"``…).
linestyle : str
    Key from LINE_GALLERY or raw mpl linestyle (``"-"``, ``"--"``…).
color : str | None
    Any mpl colour: named (``"red"``), hex (``"#e63946"``),
    or ``None`` for auto colour-cycle.
errorbar_col : str | None
    Column letter or header holding ±σ values.  ``None`` = no error bar.
markersize : float
    Marker diameter in typographic points.
linewidth : float
    Line stroke width in points.
alpha : float
    Opacity, 0.0 (transparent) … 1.0 (opaque).
zorder : int | None
    Painter's order – higher number drawn on top.  ``None`` = mpl default.
"""
col          : str
label        : str            = "Series"
marker       : str            = "circle"
linestyle    : str            = "solid"
color        : Optional[str]  = None
errorbar_col : Optional[str]  = None
markersize   : float          = 5.0
linewidth    : float          = 1.5
alpha        : float          = 1.0
zorder       : Optional[int]  = None

def resolved_marker(self) -> str:
    return MARKER_GALLERY.get(self.marker, self.marker)

def resolved_linestyle(self) -> str:
    return LINE_GALLERY.get(self.linestyle, self.linestyle)
