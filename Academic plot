from academic_plot import (
plot_academic,
Series,
AxisConfig,
LegendConfig,
GridConfig,
FigureConfig,
)

# ─────────────────────────────────────────────────────────────────────────────

# FILE & SHEET

# ─────────────────────────────────────────────────────────────────────────────

INPUT_FILE  = “data.xlsx”   # path to your Excel file (absolute or relative)
SHEET       = “Sheet1”      # sheet name (string) or 0-based index (integer)
SKIP_ROWS   = 0             # rows to skip before the header row (int)

# ─────────────────────────────────────────────────────────────────────────────

# X AXIS COLUMN

# ─────────────────────────────────────────────────────────────────────────────

# Use the Excel column letter (“A”, “B”, “AA” …) or the exact header name.

X_COL = “A”

# ─────────────────────────────────────────────────────────────────────────────

# OUTPUT FILE

# ─────────────────────────────────────────────────────────────────────────────

# Extension selects format automatically.

# Recommended:

# .pdf   → lossless vector; preferred by most journals

# .svg   → lossless vector; editable in Inkscape / Illustrator

# .png   → raster; use dpi=300 (set in FigureConfig below)

# .tiff  → raster; use dpi=300; accepted by many journals

# .eps   → Encapsulated PostScript; legacy journals

OUTPUT_FILE = “figure_1.pdf”

# ─────────────────────────────────────────────────────────────────────────────

# GLOBAL APPEARANCE

# ─────────────────────────────────────────────────────────────────────────────

# theme       : “auto”  → reads OS dark/light setting automatically

# : “light” → force white background

# : “dark”  → force dark background

# 

# font_family : “serif”      → Times-like   (most journals)

# : “sans-serif” → Helvetica-like (some journals, presentations)

# : “monospace”  → Courier-like

# : Any installed font name, e.g. “DejaVu Serif”

# 

# font_size   : base size in points (axis labels, tick labels scale from this)

# Typical journal values: 7–9 pt

THEME       = “auto”
FONT_FAMILY = “serif”
FONT_SIZE   = 9.0

# =============================================================================

# ENGINEERING LABEL REFERENCE  –  use raw strings (r”…”) for LaTeX math

# =============================================================================

# 

# LaTeX mode is activated by enclosing text in $…$

# Always prefix the string with  r  to avoid Python escape conflicts.

# 

# ── GREEK LETTERS ──────────────────────────────────────────────────────────

# α  alpha    → r”$\alpha$”          β  beta      → r”$\beta$”

# γ  gamma    → r”$\gamma$”          δ  delta     → r”$\delta$”

# ε  epsilon  → r”$\epsilon$”        ζ  zeta      → r”$\zeta$”

# η  eta      → r”$\eta$”            θ  theta     → r”$\theta$”

# λ  lambda   → r”$\lambda$”         μ  mu        → r”$\mu$”

# ν  nu       → r”$\nu$”             ρ  rho       → r”$\rho$”

# σ  sigma    → r”$\sigma$”          τ  tau       → r”$\tau$”

# φ  phi      → r”$\phi$”            χ  chi       → r”$\chi$”

# ψ  psi      → r”$\psi$”            ω  omega     → r”$\omega$”

# Δ  Delta    → r”$\Delta$”          Φ  Phi       → r”$\Phi$”

# Σ  Sigma    → r”$\Sigma$”          Ω  Omega     → r”$\Omega$”

# Π  Pi       → r”$\Pi$”             Λ  Lambda    → r”$\Lambda$”

# 

# ── SUBSCRIPTS & SUPERSCRIPTS ───────────────────────────────────────────────

# Single char  T_s    → r”$T_s$”          use underscore _

# Multi-char   T_rec  → r”$T_\mathrm{rec}$”   use \mathrm{} for roman text

# Superscript  m²     → r”m$^2$”          use caret ^

# Negative exp m⁻¹    → r”m$^{-1}$”

# Combined     m s⁻¹  → r”m s$^{-1}$”    or r”m$,$s$^{-1}$” (thin space)

# 

# ── DERIVATIVES / RATE NOTATION ─────────────────────────────────────────────

# ṁ  mass-flow rate   → r”$\dot{m}$”

# Q̇  heat rate        → r”$\dot{Q}$”

# q̇  heat flux rate   → r”$\dot{q}$”

# q″  heat flux       → r”$q’’$”          two apostrophes

# ∂T  partial deriv.  → r”$\partial T$”

# 

# ── COMMON ENGINEERING UNIT LABELS ──────────────────────────────────────────

# Temperature (°C)            → r”Temperature, $T$ (°C)”

# Temperature (K)             → r”Temperature, $T$ (K)”

# Time (s)                    → r”Time, $t$ (s)”

# Heat flux (W m⁻²)           → r”Heat flux, $q’’$ (W m$^{-2}$)”

# Heat rate (W)               → r”Heat rate, $\dot{Q}$ (W)”

# Skin wettedness (–)         → r”Skin wettedness, $w$ (–)”

# Metabolic rate (W m⁻²)      → r”Metabolic rate, $M$ (W m$^{-2}$)”

# Evaporative heat loss (W)   → r”$E_\mathrm{sk}$ (W)”

# Sweat rate (g h⁻¹)          → r”Sweat rate, $\dot{m}_\mathrm{sw}$ (g h$^{-1}$)”

# Skin temperature (°C)       → r”Skin temperature, $T_\mathrm{sk}$ (°C)”

# Core temperature (°C)       → r”Core temperature, $T_\mathrm{cr}$ (°C)”

# Blood flow (L h⁻¹)          → r”Blood flow, $\dot{V}_\mathrm{bl}$ (L h$^{-1}$)”

# Relative humidity (%)       → r”Relative humidity, $\phi$ (%)”

# Air velocity (m s⁻¹)        → r”Air velocity, $v_\mathrm{a}$ (m s$^{-1}$)”

# Wind speed (km h⁻¹)         → r”Wind speed, $U$ (km h$^{-1}$)”

# Wet-bulb globe temp (°C)    → r”WBGT (°C)”

# Physiological strain index  → r”Physiological Strain Index, PSI (–)”

# Heart rate (bpm)            → r”Heart rate, $f_\mathrm{H}$ (min$^{-1}$)”

# Oxygen uptake (mL kg⁻¹ min⁻¹) → r”$\dot{V}\mathrm{O_2}$ (mL kg$^{-1}$ min$^{-1}$)”

# Pressure (Pa)               → r”Pressure, $p$ (Pa)”

# Pressure (kPa)              → r”Pressure, $p$ (kPa)”

# Vapour pressure (kPa)       → r”Vapour pressure, $p_\mathrm{v}$ (kPa)”

# Thermal conductance (W K⁻¹) → r”Conductance, $G$ (W K$^{-1}$)”

# Density (kg m⁻³)            → r”Density, $\rho$ (kg m$^{-3}$)”

# Specific heat (J kg⁻¹ K⁻¹) → r”$c_p$ (J kg$^{-1}$ K$^{-1}$)”

# Dynamic viscosity (Pa s)    → r”Viscosity, $\mu$ (Pa s)”

# Reynolds number (–)         → r”Reynolds number, Re (–)”

# Nusselt number (–)          → r”Nusselt number, Nu (–)”

