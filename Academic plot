# ─────────────────────────────────────────────────────────────────────────────

# Internal helpers

# ─────────────────────────────────────────────────────────────────────────────

def _detect_system_theme() -> Literal[“light”, “dark”]:
try:
if platform.system() == “Darwin”:
r = subprocess.run(
[“defaults”, “read”, “-g”, “AppleInterfaceStyle”],
capture_output=True, text=True, timeout=2,
)
if r.returncode == 0 and “dark” in r.stdout.lower():
return “dark”
elif platform.system() == “Windows”:
import winreg
key = winreg.OpenKey(
winreg.HKEY_CURRENT_USER,
r”Software\Microsoft\Windows\CurrentVersion\Themes\Personalize”,
)
val, _ = winreg.QueryValueEx(key, “AppsUseLightTheme”)
return “light” if val == 1 else “dark”
elif platform.system() == “Linux”:
r = subprocess.run(
[“gsettings”, “get”, “org.gnome.desktop.interface”, “color-scheme”],
capture_output=True, text=True, timeout=2,
)
if r.returncode == 0 and “dark” in r.stdout.lower():
return “dark”
except Exception:
pass
return “light”

def _apply_theme(theme: ThemeMode) -> None:
resolved = theme if theme in (“light”, “dark”) else _detect_system_theme()
plt.style.use(“dark_background” if resolved == “dark” else “default”)

def _col_letter_to_index(letter: str) -> int:
idx = 0
for ch in letter.upper().strip():
idx = idx * 26 + (ord(ch) - ord(“A”) + 1)
return idx - 1

def _resolve_column(df: pd.DataFrame, spec: str) -> str:
if spec in df.columns:
return spec
if spec.replace(” “, “”).isalpha() and len(spec.strip()) <= 3:
try:
idx = _col_letter_to_index(spec)
if 0 <= idx < len(df.columns):
return df.columns[idx]
except Exception:
pass
raise KeyError(
f”Column ‘{spec}’ not found.\nAvailable columns: {list(df.columns)}”
)

def _style_axis(ax: plt.Axes, cfg: AxisConfig, which: str) -> None:
pad = {“labelpad”: cfg.label_pad}
if which == “x”:
ax.set_xlabel(cfg.label, **pad)
if cfg.limits:  ax.set_xlim(cfg.limits)
if cfg.log_scale: ax.set_xscale(“log”)
ax.tick_params(axis=“x”, direction=cfg.tick_direction,
which=“both” if cfg.minor_ticks else “major”)
if cfg.minor_ticks:
ax.xaxis.set_minor_locator(mticker.AutoMinorLocator())
else:
ax.set_ylabel(cfg.label, **pad)
if cfg.limits:  ax.set_ylim(cfg.limits)
if cfg.log_scale: ax.set_yscale(“log”)
ax.tick_params(axis=“y”, direction=cfg.tick_direction,
which=“both” if cfg.minor_ticks else “major”)
if cfg.minor_ticks:
ax.yaxis.set_minor_locator(mticker.AutoMinorLocator())

# ─────────────────────────────────────────────────────────────────────────────

# Main public function

# ─────────────────────────────────────────────────────────────────────────────

def plot_academic(
filename         : Union[str, Path],
sheetname        : Union[str, int] = 0,
x_col            : str             = “A”,
skip_rows        : int             = 0,
primary_series   : list[Series]    = None,
secondary_series : list[Series]    = None,
x_axis           : AxisConfig      = None,
y1_axis          : AxisConfig      = None,
y2_axis          : AxisConfig      = None,
legend           : LegendConfig    = None,
grid             : GridConfig      = None,
figure           : FigureConfig    = None,
theme            : ThemeMode       = “auto”,
font_family      : str             = “serif”,
font_size        : float           = 9.0,
) -> tuple[plt.Figure, plt.Axes]:
“”“Read an Excel sheet and render an academic-quality Matplotlib figure.

```
Returns
-------
(fig, ax1) : tuple
    The Figure and primary Axes for any post-call tweaking.
"""
if primary_series   is None: primary_series   = []
if secondary_series is None: secondary_series = []
if x_axis  is None: x_axis  = AxisConfig(label="X")
if y1_axis is None: y1_axis = AxisConfig(label="Y")
if y2_axis is None: y2_axis = AxisConfig(label="Y2")
if legend  is None: legend  = LegendConfig()
if grid    is None: grid    = GridConfig()
if figure  is None: figure  = FigureConfig()

_apply_theme(theme)
matplotlib.rcParams.update({
    "font.family"       : font_family,
    "font.size"         : font_size,
    "axes.titlesize"    : font_size + 2,
    "axes.labelsize"    : font_size,
    "xtick.labelsize"   : font_size - 1,
    "ytick.labelsize"   : font_size - 1,
    "legend.fontsize"   : legend.fontsize or (font_size - 1),
    "figure.dpi"        : figure.dpi,
    "savefig.dpi"       : figure.dpi,
    "axes.linewidth"    : 0.8,
    "xtick.major.width" : 0.8,  "ytick.major.width" : 0.8,
    "xtick.minor.width" : 0.5,  "ytick.minor.width" : 0.5,
    "xtick.major.size"  : 4.0,  "ytick.major.size"  : 4.0,
    "xtick.minor.size"  : 2.5,  "ytick.minor.size"  : 2.5,
})

fp = Path(filename)
if not fp.exists():
    raise FileNotFoundError(f"File not found: {fp.resolve()}")

df = pd.read_excel(fp, sheet_name=sheetname, skiprows=skip_rows)
df.columns = [str(c) for c in df.columns]
x_data = pd.to_numeric(df[_resolve_column(df, x_col)], errors="coerce")

fig, ax1 = plt.subplots(figsize=(figure.width_cm / 2.54,
                                 figure.height_cm / 2.54))
ax2 = ax1.twinx() if secondary_series else None

_style_axis(ax1, x_axis,  "x")
_style_axis(ax1, y1_axis, "y")
if ax2: _style_axis(ax2, y2_axis, "y2")

def _draw(ax: plt.Axes, slist: list[Series]) -> list:
    handles = []
    for s in slist:
        y  = pd.to_numeric(df[_resolve_column(df, s.col)], errors="coerce")
        kw = dict(label=s.label, marker=s.resolved_marker(),
                  linestyle=s.resolved_linestyle(),
                  markersize=s.markersize, linewidth=s.linewidth,
                  alpha=s.alpha)
        if s.color:           kw["color"]  = s.color
        if s.zorder is not None: kw["zorder"] = s.zorder

        if s.errorbar_col:
            yerr = pd.to_numeric(
                df[_resolve_column(df, s.errorbar_col)], errors="coerce")
            handles.append(
                ax.errorbar(x_data, y, yerr=yerr, **kw,
                            capsize=3, capthick=0.8, elinewidth=0.8))
        else:
            line, = ax.plot(x_data, y, **kw)
            handles.append(line)
    return handles

h1 = _draw(ax1, primary_series)
h2 = _draw(ax2, secondary_series) if ax2 else []

if figure.title:
    ax1.set_title(figure.title,
                  fontsize=figure.title_fontsize or (font_size + 2), pad=6)

if legend.show and (h1 or h2):
    kw = dict(handles=h1 + h2,
              labels=[s.label for s in primary_series + secondary_series],
              ncol=legend.ncol, frameon=legend.frameon,
              framealpha=legend.framealpha,
              fontsize=legend.fontsize or (font_size - 1))
    if legend.title: kw["title"] = legend.title
    if legend.loc == "outside right":
        kw.update(bbox_to_anchor=(1.15, 0.5), loc="center left",
                  borderaxespad=0)
    elif legend.loc == "outside lower":
        kw.update(bbox_to_anchor=(0.5, -0.28), loc="upper center")
    else:
        kw["loc"] = legend.loc
    ax1.legend(**kw)

if grid.show and grid.axis != "none":
    gkw = dict(linestyle=grid.linestyle,
               linewidth=grid.linewidth, alpha=grid.alpha)
    if grid.major: ax1.grid(True, which="major", axis=grid.axis, **gkw)
    if grid.minor: ax1.grid(True, which="minor", axis=grid.axis,
                            linewidth=grid.linewidth * 0.5, **gkw)
else:
    ax1.grid(False)

if ax2 and secondary_series and secondary_series[0].color:
    c = secondary_series[0].color
    ax2.spines["right"].set_color(c)
    ax2.tick_params(axis="y", colors=c)
    ax2.yaxis.label.set_color(c)

if figure.tight_layout:
    fig.tight_layout()

if figure.output_file:
    out = Path(figure.output_file)
    out.parent.mkdir(parents=True, exist_ok=True)
    fig.savefig(out, dpi=figure.dpi, bbox_inches="tight")
    print(f"[academic_plot] saved → {out.resolve()}")
else:
    plt.show()

return fig, ax1
```



